#!/usr/bin/env bash
#
# qrar - Encode/decode files to/from QR codes
# Version: 1.0.0
#
# Preserves file names, Unix attributes, and dates using tar.
# Supports splitting large files across multiple QR codes.
# Supports optional encryption via passphrase.
#
set -eo pipefail

readonly VERSION="1.0.0"
readonly MAGIC="QRAR"  # qrar identifier

# Default settings
ERROR_LEVEL="M"       # QR error correction level (L/M/Q/H)
QR_SIZE=10            # Dot size in pixels
OUTPUT_DIR=""         # Output directory (empty = same as input)
ENCRYPT=""            # Encryption passphrase (empty = no encryption)
FORCE=false           # Overwrite without confirmation
VERBOSE=false         # Verbose output
COMPRESSION="gz"      # Compression: gz, xz, none
MONTAGE=false         # Combine QR codes into montage image
MONTAGE_COLS=""       # Number of columns in montage (auto if empty)
PRINT_MODE=false      # Print mode: montage + PDF output
TERMINAL_OUTPUT=""    # Terminal output mode: UTF8, ANSI, ASCII (empty = disabled)
VIDEO_MODE=false      # Video output mode (mp4)
GIF_MODE=false        # GIF output mode
FRAME_DURATION=0.25   # Seconds per QR code in video/GIF (250ms)

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

#------------------------------------------------------------------------------
# Utility Functions
#------------------------------------------------------------------------------

# Get chunk limit by error correction level (bash 3.2 compatible)
# These limits target ~version 10-12 QR codes for easy scanning
# Version 10 capacities: L=271, M=213, Q=151, H=119 bytes
# Version 12 capacities: L=367, M=287, Q=209, H=159 bytes
get_chunk_limit() {
    local level="$1"
    case "$level" in
        L) echo 300 ;;
        M) echo 230 ;;
        Q) echo 170 ;;
        H) echo 130 ;;
        *) echo 230 ;;  # default to M
    esac
}

log_info() {
    echo -e "${BLUE}[INFO]${NC} $*" >&2
}

log_success() {
    echo -e "${GREEN}[OK]${NC} $*" >&2
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $*" >&2
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
}

die() {
    log_error "$@"
    exit 1
}

verbose() {
    if [[ "$VERBOSE" == true ]]; then
        log_info "$@"
    fi
}

check_dependencies() {
    local missing=""

    for cmd in qrencode zbarimg tar base64; do
        if ! command -v "$cmd" &>/dev/null; then
            missing="$missing $cmd"
        fi
    done

    if [[ -n "$missing" ]]; then
        log_error "Missing required dependencies:$missing"
        echo "" >&2
        echo "Run 'qrar install' to automatically install dependencies," >&2
        echo "or install manually:" >&2
        echo "  macOS:  brew install qrencode zbar" >&2
        echo "  Ubuntu: sudo apt install qrencode zbar-tools" >&2
        echo "  Fedora: sudo dnf install qrencode zbar" >&2
        echo "  Arch:   sudo pacman -S qrencode zbar" >&2
        echo "" >&2
        echo "Optional dependencies:" >&2
        echo "  openssl     - for encryption" >&2
        echo "  ffmpeg      - for video input/output" >&2
        echo "  ghostscript - for PDF input" >&2
        echo "  imagemagick - for montage/print output" >&2
        exit 1
    fi
}

check_openssl() {
    if ! command -v openssl &>/dev/null; then
        die "openssl is required for encryption. Run 'qrar install' or install manually."
    fi
}

check_ffmpeg() {
    if ! command -v ffmpeg &>/dev/null; then
        return 1
    fi
    return 0
}

check_imagemagick() {
    # Check for ImageMagick (either 'magick' for v7+ or 'montage' for v6)
    if command -v magick &>/dev/null; then
        echo "magick montage"
        return 0
    elif command -v montage &>/dev/null; then
        echo "montage"
        return 0
    fi
    return 1
}

# Generate video or GIF from QR code images
generate_video() {
    local output_file="$1"
    local format="$2"  # "mp4" or "gif"
    local duration="$3"
    shift 3
    local input_files=("$@")

    if ! check_ffmpeg; then
        die "ffmpeg is required for video/GIF output. Run 'qrar install' or install manually."
    fi

    # Create a temporary file list for ffmpeg concat
    local concat_file="$TEMP_DIR/concat.txt"
    : > "$concat_file"

    local last_file=""
    for img in "${input_files[@]}"; do
        # Each image shown for $duration seconds (use absolute path)
        local abs_path
        abs_path=$(cd "$(dirname "$img")" && pwd)/$(basename "$img")
        echo "file '$abs_path'" >> "$concat_file"
        echo "duration $duration" >> "$concat_file"
        last_file="$abs_path"
    done
    # Add the last image again (ffmpeg concat demuxer quirk)
    echo "file '$last_file'" >> "$concat_file"

    log_info "Creating $format..."

    if [[ "$format" == "gif" ]]; then
        # Generate GIF - simple approach works well for B&W QR codes
        ffmpeg -y -f concat -safe 0 -i "$concat_file" \
            "$output_file" -loglevel warning || \
            die "Failed to create GIF"
    else
        # Generate MP4 video
        ffmpeg -y -f concat -safe 0 -i "$concat_file" \
            -vf "format=yuv420p,pad=ceil(iw/2)*2:ceil(ih/2)*2" \
            -c:v libx264 -preset medium -crf 18 \
            "$output_file" -loglevel warning || \
            die "Failed to create video"
    fi

    log_success "Created: $output_file"
}

# Generate random session ID (8 hex chars)
generate_session_id() {
    # Use openssl if available, otherwise fall back to /dev/urandom
    if command -v openssl &>/dev/null; then
        openssl rand -hex 4
    else
        head -c 4 /dev/urandom | od -An -tx1 | tr -d ' \n'
    fi
}

# Calculate CRC32-like checksum
calc_checksum() {
    # Use cksum and extract just the numeric value
    cksum | cut -d' ' -f1
}

# Track "overwrite all" state
OVERWRITE_ALL=false

# Confirm overwrite
confirm_overwrite() {
    local file="$1"

    if [[ "$FORCE" == true || "$OVERWRITE_ALL" == true ]]; then
        return 0
    fi

    if [[ -e "$file" ]]; then
        printf "File '%s' exists. Overwrite? [y/N/a(ll)] " "$file"
        read -r REPLY
        case "$REPLY" in
            [Yy])
                return 0
                ;;
            [Aa])
                OVERWRITE_ALL=true
                return 0
                ;;
            *)
                return 1
                ;;
        esac
    fi
    return 0
}

# Clean up temporary files
TEMP_DIR=""
cleanup() {
    if [[ -n "$TEMP_DIR" && -d "$TEMP_DIR" ]]; then
        rm -rf "$TEMP_DIR"
        verbose "Cleaned up temp directory"
    fi
}

trap cleanup EXIT

#------------------------------------------------------------------------------
# Encode Functions
#------------------------------------------------------------------------------

encode_files() {
    local output_base="$1"
    shift
    local inputs=("$@")

    if [[ ${#inputs[@]} -eq 0 ]]; then
        die "No input files specified"
    fi

    # Validate inputs exist
    for input in "${inputs[@]}"; do
        if [[ ! -e "$input" ]]; then
            die "Input not found: $input"
        fi
    done

    # Create temp directory
    TEMP_DIR=$(mktemp -d)
    verbose "Using temp directory: $TEMP_DIR"

    # Determine compression flag
    local tar_compress=""
    local tar_ext=""
    case "$COMPRESSION" in
        gz)
            tar_compress="-z"
            tar_ext=".tar.gz"
            ;;
        xz)
            tar_compress="-J"
            tar_ext=".tar.xz"
            ;;
        none)
            tar_compress=""
            tar_ext=".tar"
            ;;
        *)
            die "Unknown compression: $COMPRESSION"
            ;;
    esac

    log_info "Creating archive..."

    # Create tar archive
    local archive="$TEMP_DIR/archive$tar_ext"
    if [[ -n "$tar_compress" ]]; then
        tar -c $tar_compress -f "$archive" "${inputs[@]}" 2>/dev/null || \
            die "Failed to create tar archive"
    else
        tar -c -f "$archive" "${inputs[@]}" 2>/dev/null || \
            die "Failed to create tar archive"
    fi

    local archive_size
    archive_size=$(wc -c < "$archive" | tr -d ' ')
    verbose "Archive size: $archive_size bytes"

    # Encrypt if passphrase provided
    local data_file="$archive"
    if [[ -n "$ENCRYPT" ]]; then
        check_openssl
        log_info "Encrypting data..."
        data_file="$TEMP_DIR/encrypted.bin"
        openssl enc -aes-256-cbc -pbkdf2 -salt \
            -pass "pass:$ENCRYPT" \
            -in "$archive" -out "$data_file" || \
            die "Encryption failed"
        verbose "Encrypted size: $(wc -c < "$data_file" | tr -d ' ') bytes"
    fi

    # Base64 encode
    log_info "Encoding to base64..."
    local b64_file="$TEMP_DIR/data.b64"
    base64 < "$data_file" | tr -d '\n' > "$b64_file"

    local b64_size
    b64_size=$(wc -c < "$b64_file" | tr -d ' ')
    verbose "Base64 size: $b64_size bytes"

    # Calculate checksum of original archive
    local checksum
    checksum=$(calc_checksum < "$archive")
    verbose "Archive checksum: $checksum"

    # Generate session ID
    local session_id
    session_id=$(generate_session_id)
    verbose "Session ID: $session_id"

    # Determine chunk size
    local chunk_limit
    chunk_limit=$(get_chunk_limit "$ERROR_LEVEL")

    # Calculate header overhead: QRT:V1:XX:XXX/XXX:XXXXXXXX:XXXXXXXXXX:
    # Magic(3) + : + V1(2) + : + flags(2) + : + seq(max 3) + / + total(max 3) + : + session(8) + : + checksum(max 10) + : = ~40 bytes
    local header_overhead=45
    local data_chunk_size=$((chunk_limit - header_overhead))

    # Encryption flag in header (E=encrypted, P=plain)
    local enc_flag="P"
    [[ -n "$ENCRYPT" ]] && enc_flag="E"

    # Compression flag in header
    local comp_flag
    case "$COMPRESSION" in
        gz) comp_flag="G" ;;
        xz) comp_flag="X" ;;
        none) comp_flag="N" ;;
    esac

    # Split into chunks
    local total_chunks=$(( (b64_size + data_chunk_size - 1) / data_chunk_size ))

    if [[ $total_chunks -gt 999 ]]; then
        die "Data too large: would require $total_chunks QR codes (max 999)"
    fi

    log_info "Generating $total_chunks QR code(s)..."

    # Determine output directory (only if file output is needed)
    local out_dir=""
    local base_name=""
    if [[ -n "$output_base" ]]; then
        if [[ -n "$OUTPUT_DIR" ]]; then
            out_dir="$OUTPUT_DIR"
        else
            out_dir="$(dirname "$output_base")"
        fi
        mkdir -p "$out_dir"

        base_name="$(basename "$output_base")"
        # Remove extension if present
        base_name="${base_name%.*}"
    fi

    local chunk_num=1
    local offset=0
    local -a generated_files=()

    while [[ $offset -lt $b64_size ]]; do
        # Read chunk data
        local chunk_data
        chunk_data=$(dd if="$b64_file" bs=1 skip=$offset count=$data_chunk_size 2>/dev/null)

        # Format: QRT:V1:<enc><comp>:<seq>/<total>:<session>:<checksum>:<data>
        local header="${MAGIC}:V1:${enc_flag}${comp_flag}:${chunk_num}/${total_chunks}:${session_id}:${checksum}:"
        local qr_data="${header}${chunk_data}"

        # Display in terminal if requested
        if [[ -n "$TERMINAL_OUTPUT" ]]; then
            if [[ $total_chunks -gt 1 ]]; then
                echo ""
                echo "--- QR Code $chunk_num of $total_chunks ---"
            fi
            printf '%s' "$qr_data" | qrencode -8 -l "$ERROR_LEVEL" -t "$TERMINAL_OUTPUT" -o -
        fi

        # Generate file output (skip if terminal-only mode)
        if [[ -n "$output_base" ]]; then
            # Determine output filename
            local out_file
            if [[ "$MONTAGE" == true || "$VIDEO_MODE" == true || "$GIF_MODE" == true ]]; then
                # Montage/video/gif mode: put individual QR codes in temp directory
                local qr_temp_dir="$TEMP_DIR/qrcodes"
                mkdir -p "$qr_temp_dir"
                out_file="$qr_temp_dir/$(printf '%03d' $chunk_num).png"
            elif [[ $total_chunks -eq 1 ]]; then
                out_file="$out_dir/${base_name}.png"
            else
                out_file="$out_dir/${base_name}.$(printf '%03d' $chunk_num).png"
            fi

            # Check for overwrite (skip for temp files)
            if [[ "$MONTAGE" != true && "$VIDEO_MODE" != true && "$GIF_MODE" != true ]] && ! confirm_overwrite "$out_file"; then
                die "Aborted by user"
            fi

            # Generate QR code (let qrencode auto-select smallest version that fits)
            printf '%s' "$qr_data" | qrencode -8 -l "$ERROR_LEVEL" -s "$QR_SIZE" -o "$out_file" || \
                die "Failed to generate QR code for chunk $chunk_num"

            generated_files+=("$out_file")
            verbose "Generated: $out_file (chunk $chunk_num/$total_chunks)"
        fi

        chunk_num=$((chunk_num + 1))
        offset=$((offset + data_chunk_size))
    done

    # Show file output summary (skip if terminal-only or montage/video/gif mode)
    if [[ -n "$output_base" && "$MONTAGE" != true && "$VIDEO_MODE" != true && "$GIF_MODE" != true ]]; then
        log_success "Generated $((chunk_num - 1)) QR code(s):"
        for f in "${generated_files[@]}"; do
            echo "  $f"
        done
    fi

    if [[ -n "$ENCRYPT" ]]; then
        log_warn "Data is encrypted. You will need the passphrase to decode."
    fi

    # Generate montage if requested (requires file output)
    if [[ "$MONTAGE" == true && -n "$output_base" ]]; then
        local montage_cmd
        if ! montage_cmd=$(check_imagemagick); then
            die "ImageMagick is required for --montage. Run 'qrar install' or install manually."
        fi

        # Determine montage output format from original output extension
        local orig_ext="${output_base##*.}"
        orig_ext=$(echo "$orig_ext" | tr '[:upper:]' '[:lower:]')
        local montage_ext="png"

        if [[ "$PRINT_MODE" == true ]]; then
            # Print mode always uses PDF
            montage_ext="pdf"
        else
            case "$orig_ext" in
                pdf|png|jpg|jpeg) montage_ext="$orig_ext" ;;
            esac
        fi

        local montage_file="$out_dir/${base_name}.montage.${montage_ext}"

        if ! confirm_overwrite "$montage_file"; then
            die "Aborted by user"
        fi

        log_info "Creating montage..."

        # Determine convert command for labeling
        local convert_cmd="convert"
        if command -v magick &>/dev/null; then
            convert_cmd="magick"
        fi

        # Add labels to each QR code (QR Code X of Y)
        local total_qr=${#generated_files[@]}
        local -a labeled_files=()
        local qr_num=1
        local label_dir="$TEMP_DIR/labeled"
        mkdir -p "$label_dir"
        for qr_file in "${generated_files[@]}"; do
            local labeled_file="$label_dir/$(printf '%03d' $qr_num).png"
            $convert_cmd "$qr_file" \
                -gravity South \
                -background white \
                -splice 0x40 \
                -pointsize 48 \
                -annotate +0-6 "QR Code $qr_num of $total_qr" \
                "$labeled_file" 2>/dev/null || \
                die "Failed to label QR code $qr_num"
            labeled_files+=("$labeled_file")
            qr_num=$((qr_num + 1))
        done

        # Calculate grid layout
        local num_images=${#labeled_files[@]}
        local cols="$MONTAGE_COLS"

        if [[ -z "$cols" ]]; then
            # Auto-calculate columns: aim for roughly square grid, max 6 columns
            if [[ $num_images -le 3 ]]; then
                cols=$num_images
            elif [[ $num_images -le 8 ]]; then
                cols=4
            else
                cols=6
            fi
        fi

        # Calculate rows needed (for reference, not currently used)
        local rows=$(( (num_images + cols - 1) / cols ))

        # Check if we need multi-page PDF
        local ext="${montage_file##*.}"
        ext=$(echo "$ext" | tr '[:upper:]' '[:lower:]')

        if [[ "$ext" == "pdf" ]]; then
            # A4 page settings (300 DPI)
            # A4 = 210mm × 297mm = 2480 × 3508 pixels at 300 DPI
            # With 10mm margins: 190mm × 277mm = 2244 × 3272 pixels
            local page_width=2480
            local page_height=3508
            local content_width=2244
            local content_height=3272
            local dpi=300

            # For PDF, create pages with max 48 QR codes each (6x8 grid)
            local max_per_page=48
            local page_cols=6
            local page=1
            local total_files=${#labeled_files[@]}
            local total_pages=$(( (total_files + max_per_page - 1) / max_per_page ))
            local montage_dir="$TEMP_DIR/montage"
            mkdir -p "$montage_dir"

            if [[ $total_files -le $max_per_page ]]; then
                # Single page PDF
                local temp_montage="$montage_dir/temp.png"
                $montage_cmd \
                    "${labeled_files[@]}" \
                    -tile "${cols}x" \
                    -geometry '+1+1' \
                    -gravity NorthWest \
                    -border 1 \
                    -bordercolor white \
                    -background white \
                    "$temp_montage" 2>/dev/null || \
                    die "Failed to create montage"

                # Resize to fit A4, align to top with margin, add page number
                local top_margin=120
                $convert_cmd "$temp_montage" \
                    -resize "${content_width}x${content_height}>" \
                    -gravity North \
                    -background white \
                    -splice "0x${top_margin}" \
                    -gravity North \
                    -extent "${page_width}x${page_height}" \
                    -gravity South \
                    -pointsize 36 \
                    -annotate +0+40 "qrar - Page 1 of 1" \
                    -set units PixelsPerInch -density $dpi \
                    "$montage_file" 2>/dev/null || \
                    die "Failed to create PDF"
            else
                # Multi-page PDF
                local i=0
                local -a temp_pages=()
                while [[ $i -lt $total_files ]]; do
                    local -a page_files=()
                    local j=0
                    while [[ $j -lt $max_per_page && $((i + j)) -lt $total_files ]]; do
                        page_files+=("${labeled_files[$((i + j))]}")
                        j=$((j + 1))
                    done

                    local temp_montage="$montage_dir/montage_$(printf '%03d' $page).png"
                    $montage_cmd \
                        "${page_files[@]}" \
                        -tile "${page_cols}x" \
                        -geometry '+1+1' \
                        -gravity NorthWest \
                        -border 1 \
                        -bordercolor white \
                        -background white \
                        "$temp_montage" 2>/dev/null || \
                        die "Failed to create montage page $page"

                    # Resize to fit A4, align to top with margin, add page number
                    local top_margin=120
                    local page_file="$montage_dir/page_$(printf '%03d' $page).png"
                    $convert_cmd "$temp_montage" \
                        -resize "${content_width}x${content_height}>" \
                        -gravity North \
                        -background white \
                        -splice "0x${top_margin}" \
                        -gravity North \
                        -extent "${page_width}x${page_height}" \
                        -gravity South \
                        -pointsize 36 \
                        -annotate +0+40 "qrar - Page $page of $total_pages" \
                        -set units PixelsPerInch -density $dpi \
                        "$page_file" 2>/dev/null || \
                        die "Failed to format page $page"

                    temp_pages+=("$page_file")
                    page=$((page + 1))
                    i=$((i + max_per_page))
                done

                # Combine pages into PDF with proper density
                $convert_cmd "${temp_pages[@]}" \
                    -set units PixelsPerInch -density $dpi \
                    "$montage_file" 2>/dev/null || \
                    die "Failed to create multi-page PDF"

                verbose "Created $((page - 1)) page PDF"
            fi
        else
            # Single image montage (PNG, JPG, etc.)
            $montage_cmd \
                "${labeled_files[@]}" \
                -tile "${cols}x" \
                -geometry '+1+1' \
                -gravity NorthWest \
                -border 1 \
                -bordercolor white \
                -background white \
                "$montage_file" 2>/dev/null || \
                die "Failed to create montage"
        fi

        log_success "Created montage: $montage_file"
    fi

    # Generate video if requested (requires file output)
    if [[ "$VIDEO_MODE" == true && -n "$output_base" ]]; then
        local video_file="$out_dir/${base_name}.mp4"

        if ! confirm_overwrite "$video_file"; then
            die "Aborted by user"
        fi

        generate_video "$video_file" "mp4" "$FRAME_DURATION" "${generated_files[@]}"
    fi

    # Generate GIF if requested (requires file output)
    if [[ "$GIF_MODE" == true && -n "$output_base" ]]; then
        local gif_file="$out_dir/${base_name}.gif"

        if ! confirm_overwrite "$gif_file"; then
            die "Aborted by user"
        fi

        generate_video "$gif_file" "gif" "$FRAME_DURATION" "${generated_files[@]}"
    fi
}

#------------------------------------------------------------------------------
# Decode Functions
#------------------------------------------------------------------------------

is_video_file() {
    local file="$1"
    local ext="${file##*.}"
    # Convert to lowercase (bash 3.2 compatible)
    ext=$(echo "$ext" | tr '[:upper:]' '[:lower:]')

    case "$ext" in
        mp4|mov|avi|mkv|webm|m4v|flv|wmv|3gp|gif)
            return 0
            ;;
    esac
    return 1
}

is_pdf_file() {
    local file="$1"
    local ext="${file##*.}"
    ext=$(echo "$ext" | tr '[:upper:]' '[:lower:]')

    [[ "$ext" == "pdf" ]]
}

check_ghostscript() {
    command -v gs &>/dev/null
}

#------------------------------------------------------------------------------
# OS/Package Manager Detection
#------------------------------------------------------------------------------

detect_os() {
    local os=""
    case "$(uname -s)" in
        Darwin)
            os="macos"
            ;;
        Linux)
            if [[ -f /etc/os-release ]]; then
                # Parse ID from os-release (don't source to avoid variable conflicts)
                local distro_id
                distro_id=$(grep -E "^ID=" /etc/os-release | cut -d= -f2 | tr -d '"')
                case "$distro_id" in
                    debian|ubuntu|linuxmint|pop)
                        os="debian"
                        ;;
                    fedora|rhel|centos|rocky|alma)
                        os="fedora"
                        ;;
                    arch|manjaro|endeavouros)
                        os="arch"
                        ;;
                    alpine)
                        os="alpine"
                        ;;
                    opensuse*|sles)
                        os="opensuse"
                        ;;
                    *)
                        os="linux"
                        ;;
                esac
            else
                os="linux"
            fi
            ;;
        FreeBSD)
            os="freebsd"
            ;;
        *)
            os="unknown"
            ;;
    esac
    echo "$os"
}

detect_package_manager() {
    local os="$1"
    local pm=""

    case "$os" in
        macos)
            if command -v brew &>/dev/null; then
                pm="brew"
            else
                pm="none"
            fi
            ;;
        debian)
            pm="apt"
            ;;
        fedora)
            if command -v dnf &>/dev/null; then
                pm="dnf"
            else
                pm="yum"
            fi
            ;;
        arch)
            pm="pacman"
            ;;
        alpine)
            pm="apk"
            ;;
        opensuse)
            pm="zypper"
            ;;
        freebsd)
            pm="pkg"
            ;;
        *)
            pm="none"
            ;;
    esac
    echo "$pm"
}

get_install_commands() {
    local pm="$1"
    local install_required=""
    local install_optional=""

    case "$pm" in
        brew)
            # macOS Homebrew
            install_required="brew install qrencode zbar"
            install_optional="brew install openssl ffmpeg ghostscript imagemagick"
            ;;
        apt)
            # Debian/Ubuntu - zbar CLI tools are in zbar-tools package
            install_required="sudo apt update && sudo apt install -y qrencode zbar-tools"
            install_optional="sudo apt install -y openssl ffmpeg ghostscript imagemagick"
            ;;
        dnf)
            # Fedora - ImageMagick has capital letters
            install_required="sudo dnf install -y qrencode zbar"
            install_optional="sudo dnf install -y openssl ffmpeg ghostscript ImageMagick"
            ;;
        yum)
            # RHEL/CentOS - ImageMagick has capital letters
            install_required="sudo yum install -y qrencode zbar"
            install_optional="sudo yum install -y openssl ffmpeg ghostscript ImageMagick"
            ;;
        pacman)
            # Arch Linux - all lowercase
            install_required="sudo pacman -S --noconfirm qrencode zbar"
            install_optional="sudo pacman -S --noconfirm openssl ffmpeg ghostscript imagemagick"
            ;;
        apk)
            # Alpine Linux - qrencode CLI is in libqrencode-tools
            install_required="sudo apk add libqrencode-tools zbar"
            install_optional="sudo apk add openssl ffmpeg ghostscript imagemagick"
            ;;
        zypper)
            # openSUSE - ImageMagick has capital letters
            install_required="sudo zypper install -y qrencode zbar"
            install_optional="sudo zypper install -y openssl ffmpeg ghostscript ImageMagick"
            ;;
        pkg)
            # FreeBSD - libqrencode for qrencode, ImageMagick7 for IM
            install_required="sudo pkg install -y libqrencode zbar"
            install_optional="sudo pkg install -y openssl ffmpeg ghostscript10 ImageMagick7"
            ;;
        *)
            install_required=""
            install_optional=""
            ;;
    esac

    echo "$install_required|$install_optional"
}

# Build install command for only the missing optional packages
build_optional_install_cmd() {
    local pm="$1"
    local missing="$2"

    # Map generic names to package manager specific names
    local packages=""
    for pkg in $missing; do
        case "$pm" in
            brew)
                packages="$packages $pkg"
                ;;
            apt)
                packages="$packages $pkg"
                ;;
            dnf|yum)
                case "$pkg" in
                    imagemagick) packages="$packages ImageMagick" ;;
                    *) packages="$packages $pkg" ;;
                esac
                ;;
            pacman)
                packages="$packages $pkg"
                ;;
            apk)
                packages="$packages $pkg"
                ;;
            zypper)
                case "$pkg" in
                    imagemagick) packages="$packages ImageMagick" ;;
                    *) packages="$packages $pkg" ;;
                esac
                ;;
            pkg)
                case "$pkg" in
                    imagemagick) packages="$packages ImageMagick7" ;;
                    ghostscript) packages="$packages ghostscript10" ;;
                    *) packages="$packages $pkg" ;;
                esac
                ;;
        esac
    done

    # Build the command
    case "$pm" in
        brew) echo "brew install$packages" ;;
        apt) echo "sudo apt install -y$packages" ;;
        dnf) echo "sudo dnf install -y$packages" ;;
        yum) echo "sudo yum install -y$packages" ;;
        pacman) echo "sudo pacman -S --noconfirm$packages" ;;
        apk) echo "sudo apk add$packages" ;;
        zypper) echo "sudo zypper install -y$packages" ;;
        pkg) echo "sudo pkg install -y$packages" ;;
    esac
}

install_dependencies() {
    local install_script=false
    local deps_only=false

    # Detect if running via curl | bash (stdin is not a terminal and script source is not a file)
    local piped_install=false
    local script_path="${BASH_SOURCE[0]}"
    if [[ -z "$script_path" || ! -f "$script_path" ]]; then
        piped_install=true
    fi

    # Parse install subcommand options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --deps-only)
                deps_only=true
                shift
                ;;
            --script-only)
                install_script=true
                deps_only=true  # Skip dependency install
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local os
    os=$(detect_os)
    local pm
    pm=$(detect_package_manager "$os")

    log_info "Detected OS: $os"
    log_info "Package manager: $pm"

    if [[ "$pm" == "none" ]]; then
        if [[ "$os" == "macos" ]]; then
            log_error "Homebrew not found. Install it first:"
            echo '  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"' >&2
        else
            log_error "Could not detect a supported package manager."
            echo "Please install the following dependencies manually:" >&2
            echo "  Required: qrencode, zbar (zbarimg)" >&2
            echo "  Optional: openssl, ffmpeg, ghostscript, imagemagick" >&2
        fi
        exit 1
    fi

    local commands
    commands=$(get_install_commands "$pm")
    local install_required="${commands%|*}"
    local install_optional="${commands#*|}"

    if [[ "$deps_only" == false || "$install_script" == false ]]; then
        # Check what's missing
        local missing_required=""
        for cmd in qrencode zbarimg; do
            if ! command -v "$cmd" &>/dev/null; then
                missing_required="$missing_required $cmd"
            fi
        done

        local missing_optional=""
        for cmd in openssl ffmpeg gs magick montage; do
            if ! command -v "$cmd" &>/dev/null; then
                case "$cmd" in
                    gs) missing_optional="$missing_optional ghostscript" ;;
                    magick|montage)
                        if ! command -v magick &>/dev/null && ! command -v montage &>/dev/null; then
                            missing_optional="$missing_optional imagemagick"
                        fi
                        ;;
                    *) missing_optional="$missing_optional $cmd" ;;
                esac
            fi
        done
        # Remove duplicates and trim whitespace from missing_optional
        missing_optional=$(echo "$missing_optional" | tr ' ' '\n' | sort -u | tr '\n' ' ' | xargs)

        if [[ -n "$missing_required" ]]; then
            log_info "Installing required dependencies..."
            echo "  Running: $install_required" >&2
            echo "" >&2

            if ! eval "$install_required"; then
                die "Failed to install required dependencies"
            fi
            log_success "Required dependencies installed"
        else
            log_success "All required dependencies already installed"
        fi

        if [[ -n "$missing_optional" ]]; then
            # Build install command for only missing packages
            local optional_install_cmd
            optional_install_cmd=$(build_optional_install_cmd "$pm" "$missing_optional")

            echo "" >&2
            log_info "Missing optional dependencies:$missing_optional"
            printf "Install them? [y/N] "
            if [[ "$piped_install" == true ]]; then
                read -r REPLY < /dev/tty
            else
                read -r REPLY
            fi
            if [[ "$REPLY" =~ ^[Yy]$ ]]; then
                log_info "Installing optional dependencies..."
                echo "  Running: $optional_install_cmd" >&2
                echo "" >&2

                if ! eval "$optional_install_cmd"; then
                    log_warn "Some optional dependencies may have failed to install"
                else
                    log_success "Optional dependencies installed"
                fi
            fi
        else
            log_success "All optional dependencies already installed"
        fi
    fi

    # Install script
    if [[ "$deps_only" == false ]]; then
        echo "" >&2
        offer_script_install "$piped_install"
    elif [[ "$install_script" == true ]]; then
        offer_script_install "$piped_install"
    fi
}

offer_script_install() {
    local piped_install="$1"
    local local_bin="$HOME/.local/bin"
    local system_bin="/usr/local/bin"

    # Check if ~/.local/bin is in PATH
    if [[ ":$PATH:" == *":$local_bin:"* ]]; then
        echo "Where would you like to install qrar?" >&2
        echo "  1) $local_bin (user-local, no sudo required)" >&2
        echo "  2) $system_bin (system-wide, requires sudo)" >&2
        echo "  3) Skip installation" >&2
        printf "Choice [1/2/3]: "
        if [[ "$piped_install" == true ]]; then
            read -r choice < /dev/tty
        else
            read -r choice
        fi
        case "$choice" in
            1)
                install_script_to_path "$local_bin/qrar" "$piped_install"
                ;;
            2)
                install_script_to_path "$system_bin/qrar" "$piped_install"
                ;;
            *)
                log_info "Skipping script installation"
                ;;
        esac
    else
        printf "Install qrar to $system_bin? [y/N] "
        if [[ "$piped_install" == true ]]; then
            read -r REPLY < /dev/tty
        else
            read -r REPLY
        fi
        if [[ "$REPLY" =~ ^[Yy]$ ]]; then
            install_script_to_path "$system_bin/qrar" "$piped_install"
        fi
    fi
}

install_script_to_path() {
    local target="$1"
    local piped_install="$2"
    local target_dir
    target_dir=$(dirname "$target")

    local script_path="${BASH_SOURCE[0]}"

    # Resolve symlinks to get the actual script path
    if [[ -n "$script_path" && -f "$script_path" ]]; then
        while [[ -L "$script_path" ]]; do
            script_path=$(readlink "$script_path")
        done
    fi

    log_info "Installing qrar to $target..."

    # Create directory if needed (for ~/.local/bin)
    if [[ ! -d "$target_dir" ]]; then
        mkdir -p "$target_dir"
    fi

    local install_ok=false

    if [[ "$piped_install" == true ]]; then
        # Running via curl | bash - download fresh copy
        local download_url="${QRAR_DOWNLOAD_URL:-https://raw.githubusercontent.com/coreh/qrar/main/qrar}"
        log_info "Downloading qrar from $download_url..."

        local tmp_script
        tmp_script=$(mktemp)
        trap "rm -f '$tmp_script'; cleanup" EXIT

        if curl -fsSL "$download_url" -o "$tmp_script"; then
            chmod +x "$tmp_script"
            if [[ -w "$target_dir" ]]; then
                cp "$tmp_script" "$target" || die "Failed to copy qrar to $target"
                chmod 755 "$target" || die "Failed to make qrar executable"
                install_ok=true
            else
                sudo cp "$tmp_script" "$target" || die "Failed to copy qrar to $target (sudo)"
                sudo chmod 755 "$target" || die "Failed to make qrar executable (sudo)"
                install_ok=true
            fi
        else
            die "Failed to download qrar from $download_url"
        fi

        rm -f "$tmp_script"
        trap cleanup EXIT
    else
        # Running from file - copy directly
        if [[ -w "$target_dir" ]]; then
            cp "$script_path" "$target" || die "Failed to copy qrar to $target"
            chmod 755 "$target" || die "Failed to make qrar executable"
            install_ok=true
        else
            sudo cp "$script_path" "$target" || die "Failed to copy qrar to $target (sudo)"
            sudo chmod 755 "$target" || die "Failed to make qrar executable (sudo)"
            install_ok=true
        fi
    fi

    if [[ "$install_ok" == true ]]; then
        log_success "Installed qrar to $target"
    else
        die "Failed to install qrar to $target"
    fi
}

extract_video_frames() {
    local video="$1"
    local output_dir="$2"

    verbose "Extracting frames from: $video"

    # Check if it's a GIF (extract all frames) or video (extract at 5fps)
    local ext="${video##*.}"
    ext=$(echo "$ext" | tr '[:upper:]' '[:lower:]')

    if [[ "$ext" == "gif" ]]; then
        # GIFs: extract every frame
        ffmpeg -y -loglevel error -i "$video" "$output_dir/frame_%06d.png" || \
            die "Failed to extract frames from: $video"
    else
        # Videos: extract at 10fps for reliable QR code capture
        ffmpeg -i "$video" -vf "fps=10" -q:v 2 "$output_dir/frame_%06d.jpg" \
            -loglevel error -y 2>/dev/null || \
            die "Failed to extract frames from: $video"
    fi

    local frame_count
    frame_count=$(find "$output_dir" -name "frame_*.jpg" -o -name "frame_*.png" 2>/dev/null | wc -l | tr -d ' ')
    verbose "Extracted $frame_count frames"
}

extract_pdf_pages() {
    local pdf="$1"
    local output_dir="$2"

    verbose "Extracting pages from PDF: $pdf"

    # Use ImageMagick to convert PDF pages to images (requires ghostscript)
    local convert_cmd=""
    if command -v magick &>/dev/null; then
        convert_cmd="magick"
    elif command -v convert &>/dev/null; then
        convert_cmd="convert"
    else
        die "ImageMagick is required for PDF input. Run 'qrar install' or install manually."
    fi

    # Convert at 300 DPI for good QR code readability
    $convert_cmd -density 300 "$pdf" -quality 90 "$output_dir/page_%03d.png" 2>/dev/null || \
        die "Failed to extract pages from PDF: $pdf (is ghostscript installed?)"

    local page_count
    page_count=$(ls -1 "$output_dir"/page_*.png 2>/dev/null | wc -l | tr -d ' ')
    verbose "Extracted $page_count pages"
}

scan_images() {
    # Output results to stdout, one per line
    local inputs=("$@")

    for input in "${inputs[@]}"; do
        verbose "Scanning: $input"

        # Run zbarimg with QR-only mode
        local scan_output
        if scan_output=$(zbarimg --raw -q -Sdisable -Sqrcode.enable "$input" 2>/dev/null); then
            # Process each line (each detected QR code)
            echo "$scan_output" | while IFS= read -r line; do
                # Remove trailing whitespace/newlines
                line="${line%"${line##*[![:space:]]}"}"

                # Check if it's our format
                if [[ "$line" == "${MAGIC}:V1:"* ]]; then
                    echo "$line"
                    verbose "Found QRT code in: $input"
                fi
            done
        fi
    done
}

parse_chunk() {
    local data="$1"

    # Format: QRT:V1:<enc><comp>:<seq>/<total>:<session>:<checksum>:<data>
    local rest="${data#${MAGIC}:V1:}"

    # Parse flags (2 chars)
    local flags="${rest%%:*}"
    rest="${rest#*:}"

    # Parse seq/total
    local seq_total="${rest%%:*}"
    rest="${rest#*:}"

    # Parse session
    local session="${rest%%:*}"
    rest="${rest#*:}"

    # Parse checksum
    local checksum="${rest%%:*}"
    rest="${rest#*:}"

    # Rest is data
    local chunk_data="$rest"

    # Parse seq and total
    local seq="${seq_total%/*}"
    local total="${seq_total#*/}"

    # Parse flags
    local enc_flag="${flags:0:1}"
    local comp_flag="${flags:1:1}"

    echo "$session|$seq|$total|$checksum|$enc_flag|$comp_flag|$chunk_data"
}

decode_files() {
    local output_path="$1"
    shift
    local inputs=("$@")

    if [[ ${#inputs[@]} -eq 0 ]]; then
        die "No input files specified"
    fi

    # Create temp directory
    TEMP_DIR=$(mktemp -d)
    verbose "Using temp directory: $TEMP_DIR"

    local all_images=""

    # Process inputs: expand videos and PDFs to images
    for input in "${inputs[@]}"; do
        if [[ ! -e "$input" ]]; then
            log_warn "Input not found, skipping: $input"
            continue
        fi

        if is_video_file "$input"; then
            if ! check_ffmpeg; then
                log_warn "ffmpeg not found, skipping video: $input"
                continue
            fi

            local frame_dir="$TEMP_DIR/frames_$$_${RANDOM}"
            mkdir -p "$frame_dir"
            extract_video_frames "$input" "$frame_dir"

            # Add extracted frames to image list (jpg for videos, png for gifs)
            for frame in "$frame_dir"/frame_*.jpg "$frame_dir"/frame_*.png; do
                if [[ -f "$frame" ]]; then
                    all_images="$all_images $frame"
                fi
            done
        elif is_pdf_file "$input"; then
            if ! check_ghostscript; then
                log_warn "ghostscript not found, skipping PDF: $input"
                continue
            fi

            local pdf_dir="$TEMP_DIR/pdf_$$_${RANDOM}"
            mkdir -p "$pdf_dir"
            extract_pdf_pages "$input" "$pdf_dir"

            # Add extracted pages to image list
            for page in "$pdf_dir"/page_*.png; do
                if [[ -f "$page" ]]; then
                    all_images="$all_images $page"
                fi
            done
        else
            all_images="$all_images $input"
        fi
    done

    if [[ -z "$all_images" ]]; then
        die "No valid images to process"
    fi

    # Count images
    local img_count=0
    for _ in $all_images; do
        img_count=$((img_count + 1))
    done

    log_info "Scanning $img_count image(s)..."

    # Scan all images for QR codes and save to temp file
    local qr_file="$TEMP_DIR/qrcodes.txt"
    : > "$qr_file"

    for img in $all_images; do
        scan_images "$img" >> "$qr_file"
    done

    local qr_count
    qr_count=$(wc -l < "$qr_file" | tr -d ' ')

    if [[ $qr_count -eq 0 ]]; then
        die "No qrar codes found in the input"
    fi

    log_info "Found $qr_count qrar code(s)"

    # Parse all chunks and group by session ID
    # Store chunks in temp files per session
    local sessions_dir="$TEMP_DIR/sessions"
    mkdir -p "$sessions_dir"

    local sessions_found=""
    local session_info_file="$TEMP_DIR/session_info.txt"
    : > "$session_info_file"

    while IFS= read -r qr_data; do
        local parsed
        parsed=$(parse_chunk "$qr_data")

        local session seq total checksum enc_flag comp_flag chunk_data
        IFS='|' read -r session seq total checksum enc_flag comp_flag chunk_data <<< "$parsed"

        # Create session directory if needed
        local sess_dir="$sessions_dir/$session"
        if [[ ! -d "$sess_dir" ]]; then
            mkdir -p "$sess_dir"
            sessions_found="$sessions_found $session"
            # Store session info
            echo "$session|$total|$checksum|$enc_flag|$comp_flag" >> "$session_info_file"
        fi

        # Store chunk data
        echo "$chunk_data" > "$sess_dir/chunk_$seq.txt"

    done < "$qr_file"

    # Count unique sessions
    local session_count=0
    for _ in $sessions_found; do
        session_count=$((session_count + 1))
    done

    if [[ $session_count -eq 0 ]]; then
        die "No valid sessions found"
    fi

    if [[ $session_count -gt 1 ]]; then
        log_warn "Multiple sessions found:"
        while IFS='|' read -r session total checksum enc_flag comp_flag; do
            # Count chunks we have for this session
            local chunk_count
            chunk_count=$(ls -1 "$sessions_dir/$session"/chunk_*.txt 2>/dev/null | wc -l | tr -d ' ')

            local enc_str="unencrypted"
            [[ "$enc_flag" == "E" ]] && enc_str="encrypted"

            echo "  Session $session: $chunk_count/$total chunks ($enc_str)"
        done < "$session_info_file"
        log_info "Using session with most complete data..."
    fi

    # Find session with most chunks (or complete)
    local best_session=""
    local best_completion=0
    local best_total=0
    local best_checksum=""
    local best_enc_flag=""
    local best_comp_flag=""

    while IFS='|' read -r session total checksum enc_flag comp_flag; do
        local chunk_count
        chunk_count=$(ls -1 "$sessions_dir/$session"/chunk_*.txt 2>/dev/null | wc -l | tr -d ' ')

        if [[ $chunk_count -eq $total ]]; then
            best_session="$session"
            best_completion=$chunk_count
            best_total=$total
            best_checksum="$checksum"
            best_enc_flag="$enc_flag"
            best_comp_flag="$comp_flag"
            break
        elif [[ $chunk_count -gt $best_completion ]]; then
            best_session="$session"
            best_completion=$chunk_count
            best_total=$total
            best_checksum="$checksum"
            best_enc_flag="$enc_flag"
            best_comp_flag="$comp_flag"
        fi
    done < "$session_info_file"

    log_info "Processing session: $best_session"

    # Check for missing chunks
    local missing=""
    local missing_count=0
    for ((i=1; i<=best_total; i++)); do
        if [[ ! -f "$sessions_dir/$best_session/chunk_$i.txt" ]]; then
            missing="$missing $i"
            missing_count=$((missing_count + 1))
        fi
    done

    if [[ $missing_count -gt 0 ]]; then
        log_error "Missing chunks:$missing"
        die "Cannot decode: missing $missing_count of $best_total chunks"
    fi

    log_success "All $best_total chunks found"

    # Reassemble data in order
    log_info "Reassembling data..."

    local b64_file="$TEMP_DIR/data.b64"
    : > "$b64_file"  # Create empty file

    for ((i=1; i<=best_total; i++)); do
        cat "$sessions_dir/$best_session/chunk_$i.txt" >> "$b64_file"
    done

    # Base64 decode
    local data_file="$TEMP_DIR/data.bin"
    base64 -d < "$b64_file" > "$data_file" || \
        die "Base64 decoding failed"

    # Decrypt if encrypted
    local archive_file="$data_file"
    if [[ "$best_enc_flag" == "E" ]]; then
        check_openssl
        log_info "Data is encrypted"

        if [[ -z "$ENCRYPT" ]]; then
            printf "Enter decryption passphrase: "
            read -rs ENCRYPT
            echo
        fi

        archive_file="$TEMP_DIR/decrypted.bin"
        openssl enc -aes-256-cbc -pbkdf2 -d \
            -pass "pass:$ENCRYPT" \
            -in "$data_file" -out "$archive_file" 2>/dev/null || \
            die "Decryption failed. Wrong passphrase?"
    fi

    # Verify checksum
    local actual_checksum
    actual_checksum=$(calc_checksum < "$archive_file")

    if [[ "$actual_checksum" != "$best_checksum" ]]; then
        log_warn "Checksum mismatch! Expected: $best_checksum, Got: $actual_checksum"
        log_warn "Data may be corrupted"
    else
        verbose "Checksum verified: $best_checksum"
    fi

    # Determine output directory
    local out_dir
    if [[ -n "$output_path" ]]; then
        out_dir="$output_path"
    elif [[ -n "$OUTPUT_DIR" ]]; then
        out_dir="$OUTPUT_DIR"
    else
        out_dir="."
    fi

    # List contents first
    log_info "Archive contents:"
    tar -tvf "$archive_file" 2>/dev/null | head -20

    local file_count
    file_count=$(tar -tvf "$archive_file" 2>/dev/null | wc -l | tr -d ' ')
    if [[ $file_count -gt 20 ]]; then
        echo "  ... and $((file_count - 20)) more files"
    fi

    # Check for overwrites
    if [[ "$FORCE" != true ]]; then
        local would_overwrite=""
        local overwrite_count=0

        while IFS= read -r file; do
            # Remove leading ./ if present
            file="${file#./}"
            if [[ -e "$out_dir/$file" ]]; then
                would_overwrite="$would_overwrite $file"
                overwrite_count=$((overwrite_count + 1))
            fi
        done < <(tar -tf "$archive_file" 2>/dev/null)

        if [[ $overwrite_count -gt 0 ]]; then
            log_warn "The following files would be overwritten:"
            local shown=0
            for f in $would_overwrite; do
                if [[ $shown -lt 10 ]]; then
                    echo "  $f"
                    shown=$((shown + 1))
                fi
            done
            if [[ $overwrite_count -gt 10 ]]; then
                echo "  ... and $((overwrite_count - 10)) more"
            fi

            printf "Continue? [y/N] "
            read -r REPLY
            if [[ ! "$REPLY" =~ ^[Yy]$ ]]; then
                die "Aborted by user"
            fi
        fi
    fi

    # Extract archive
    log_info "Extracting to: $out_dir"
    mkdir -p "$out_dir"

    tar -xpf "$archive_file" -C "$out_dir" || \
        die "Failed to extract archive"

    log_success "Successfully decoded and extracted files"
}

#------------------------------------------------------------------------------
# Help and Usage
#------------------------------------------------------------------------------

show_help() {
    cat << 'EOF'
qrar - Encode/decode files to/from QR codes

USAGE:
    qrar encode [OPTIONS] -o <output> <file>...
    qrar decode [OPTIONS] -o <output> <image>...
    qrar install [OPTIONS]

COMMANDS:
    encode    Encode files/directories into QR code image(s)
    decode    Decode QR code image(s)/video(s) back to files
    install   Install dependencies and optionally the script itself

OPTIONS:
    -o, --output <path>     Output path (file for encode, directory for decode)
    -O, --output-dir <dir>  Output directory
    -l, --level <L|M|Q|H>   Error correction level (default: M)
                            L=7%, M=15%, Q=25%, H=30% recovery
    -s, --size <pixels>     QR code dot size (default: 10)
    -c, --compression <type> Compression: gz, xz, none (default: gz)
    -m, --montage           Combine QR codes into single image
    -P, --print             Print mode: montage as multi-page PDF
    --montage-cols <n>      Number of columns in montage (default: auto)
    -T, --terminal [mode]   Display QR codes in terminal (default: UTF8)
                            Modes: UTF8, ANSI, ASCII, UTF8i, ANSI256
                            If -o is omitted, only displays (no file output)
    -V, --video             Create MP4 video cycling through QR codes
    -G, --gif               Create animated GIF cycling through QR codes
    --frame-duration <sec>  Seconds per QR code in video/GIF (default: 2)
    -e, --encrypt           Encrypt data (will prompt for passphrase)
    -p, --passphrase <pass> Encryption/decryption passphrase
    -f, --force             Overwrite files without confirmation
    --verbose               Verbose output
    -h, --help              Show this help message
    -v, --version           Show version

EXAMPLES:
    # Encode a single file
    qrar encode -o backup.png important.txt

    # Encode multiple files with encryption
    qrar encode -e -o secrets.png file1.txt file2.txt

    # Encode a directory
    qrar encode -o project.png ./my_project/

    # Encode with printable PDF (for printing/archiving)
    qrar encode -P -o backup largefile.bin

    # Encode with PNG montage (all QR codes in one image)
    qrar encode -m -o backup.png largefile.bin

    # Encode and display in terminal (also saves files)
    qrar encode -T -o backup.png message.txt

    # Display in terminal only (no file output)
    qrar encode -T message.txt

    # Create animated GIF of QR codes
    qrar encode -G -o backup largefile.bin

    # Create MP4 video with 3 seconds per QR code
    qrar encode -V --frame-duration 3 -o backup largefile.bin

    # Decode from an image
    qrar decode -o ./restored/ backup.png

    # Decode from multiple images (for split data)
    qrar decode -o ./restored/ backup.qr.*.png

    # Decode from a video recording
    qrar decode -o ./restored/ recording.mp4

    # Decode from mixed sources
    qrar decode -o ./restored/ photo.jpg video.mp4 screenshot.png

NOTES:
    - Large files are automatically split across multiple QR codes
    - Videos are scanned frame-by-frame for QR codes
    - PDFs are scanned page-by-page (requires ghostscript)
    - Multiple QR codes in a single image are detected
    - File metadata (permissions, dates) is preserved via tar
    - QR codes from other sources are ignored

ERROR CORRECTION LEVELS:
    L - Low (7% recovery)      - ~300 bytes/QR code
    M - Medium (15% recovery)  - ~230 bytes/QR code (default)
    Q - Quartile (25% recovery)- ~170 bytes/QR code
    H - High (30% recovery)    - ~130 bytes/QR code

    Chunk sizes are tuned for ~version 10-12 QR codes which are
    easy to scan with phone cameras. Larger data is automatically
    split across multiple QR codes.

INSTALL COMMAND:
    qrar install             Install dependencies and offer to install script
    qrar install --deps-only Only install dependencies, not the script
    qrar install --script-only Only install the script to PATH

    Supported package managers:
    - macOS:   Homebrew (brew)
    - Debian:  apt (Ubuntu, Mint, Pop!_OS)
    - Fedora:  dnf/yum (RHEL, CentOS, Rocky, Alma)
    - Arch:    pacman (Manjaro, EndeavourOS)
    - Alpine:  apk
    - openSUSE: zypper
    - FreeBSD: pkg

EOF
    echo "Version: $VERSION"
}

show_version() {
    echo "qrar version $VERSION"
}

#------------------------------------------------------------------------------
# Main
#------------------------------------------------------------------------------

main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi

    local command=""
    local output=""
    local inputs=()

    # Parse command
    case "${1:-}" in
        encode|decode)
            command="$1"
            shift
            # Check dependencies only for encode/decode
            check_dependencies
            ;;
        install)
            shift
            install_dependencies "$@"
            exit 0
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        -v|--version)
            show_version
            exit 0
            ;;
        *)
            die "Unknown command: ${1:-}. Use 'encode', 'decode', or 'install'."
            ;;
    esac

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -o|--output)
                output="$2"
                shift 2
                ;;
            -O|--output-dir)
                OUTPUT_DIR="$2"
                shift 2
                ;;
            -l|--level)
                ERROR_LEVEL=$(echo "$2" | tr '[:lower:]' '[:upper:]')
                case "$ERROR_LEVEL" in
                    L|M|Q|H) ;;
                    *) die "Invalid error level: $2. Must be L, M, Q, or H." ;;
                esac
                shift 2
                ;;
            -s|--size)
                QR_SIZE="$2"
                shift 2
                ;;
            -c|--compression)
                COMPRESSION="$2"
                case "$COMPRESSION" in
                    gz|xz|none) ;;
                    *) die "Invalid compression: $2. Must be gz, xz, or none." ;;
                esac
                shift 2
                ;;
            -e|--encrypt)
                if [[ -z "$ENCRYPT" ]]; then
                    printf "Enter encryption passphrase: "
                    read -rs ENCRYPT
                    echo
                    printf "Confirm passphrase: "
                    read -rs confirm
                    echo
                    if [[ "$ENCRYPT" != "$confirm" ]]; then
                        die "Passphrases do not match"
                    fi
                fi
                shift
                ;;
            -p|--passphrase)
                ENCRYPT="$2"
                shift 2
                ;;
            -f|--force)
                FORCE=true
                shift
                ;;
            --verbose)
                VERBOSE=true
                shift
                ;;
            -m|--montage)
                MONTAGE=true
                shift
                ;;
            -P|--print)
                PRINT_MODE=true
                MONTAGE=true
                shift
                ;;
            --montage-cols)
                MONTAGE_COLS="$2"
                shift 2
                ;;
            -T|--terminal)
                # Default to UTF8 if no argument given or next arg is an option
                if [[ -z "${2:-}" || "$2" == -* ]]; then
                    TERMINAL_OUTPUT="UTF8"
                    shift
                else
                    case "$2" in
                        UTF8|ANSI|ANSI256|ASCII|ASCIIi|UTF8i|ANSIUTF8|ANSIUTF8i|ANSI256UTF8)
                            TERMINAL_OUTPUT="$2"
                            shift 2
                            ;;
                        *)
                            TERMINAL_OUTPUT="UTF8"
                            shift
                            ;;
                    esac
                fi
                ;;
            -V|--video)
                VIDEO_MODE=true
                shift
                ;;
            -G|--gif)
                GIF_MODE=true
                shift
                ;;
            --frame-duration)
                FRAME_DURATION="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            -v|--version)
                show_version
                exit 0
                ;;
            --)
                shift
                inputs+=("$@")
                break
                ;;
            -*)
                die "Unknown option: $1"
                ;;
            *)
                inputs+=("$1")
                shift
                ;;
        esac
    done

    # Execute command
    case "$command" in
        encode)
            if [[ -z "$output" && -z "$OUTPUT_DIR" ]]; then
                if [[ -n "$TERMINAL_OUTPUT" ]]; then
                    # Terminal-only mode: no file output
                    output=""
                elif [[ ${#inputs[@]} -gt 0 ]]; then
                    # Default output name based on first input
                    local first="${inputs[0]}"
                    first="${first%/}"  # Remove trailing slash
                    output="$(basename "$first").qr.png"
                else
                    die "No output specified. Use -o <output> or -T for terminal display"
                fi
            fi
            encode_files "$output" "${inputs[@]}"
            ;;
        decode)
            decode_files "${output:-.}" "${inputs[@]}"
            ;;
    esac
}

main "$@"
